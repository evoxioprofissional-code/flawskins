# Supabase — copie para .env.local e preencha com os valores do seu projeto
# Painel: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mercado Pago (Pix das rifas) — server-only, NUNCA commitar valores reais
# Painel: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# Segredo que protege o webhook (gere um valor aleatório; o mesmo valor deve
# estar gravado na tabela public.app_config -> key 'mp_webhook_secret')
MP_WEBHOOK_SECRET=
# URL pública do site (para o Mercado Pago notificar o webhook)
NEXT_PUBLIC_SITE_URL=https://flawskins.com.br

# OAuth do Mercado Pago (criadores conectarem a conta deles p/ receber rifas)
# Redirect URI a registrar no app do MP: <NEXT_PUBLIC_SITE_URL>/api/mp/oauth/callback
MP_CLIENT_ID=
MP_CLIENT_SECRET=
# Service role do Supabase (server-only) — necessária na FASE do split das cotas
SUPABASE_SERVICE_ROLE_KEY=
